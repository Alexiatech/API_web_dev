---
// PlantDetail component - haalt 1 plant op uit de Trefle API en toont
// alle info. 
// vanuit src/pages/soorten/[id].astro (daar wordt `id` als prop meegegeven).

const { id } = Astro.props;
const TOKEN = import.meta.env.TREFLE_TOKEN;

const response = await fetch(`https://trefle.io/api/v1/plants/${id}?token=${TOKEN}`);
const data = await response.json();
const plant = data.data;

// Stukjes uit main_species halen, met veilige defaults
const soort = plant.main_species ?? {};
const specs = soort.specifications ?? {};
const growth = soort.growth ?? {};
const flower = soort.flower ?? {};
const foliage = soort.foliage ?? {};
const fruit = soort.fruit_or_seed ?? {};

function toonWaarde(w) {
    if (w === true) return "Yes";
    if (w === false) return "No";
    if (Array.isArray(w)) return w.join(", ");
    return w;
}

function pakNaam(val) {
    if (val === null || val === undefined) return val;
    if (typeof val === "string") return val;
    if (typeof val === "object") return val.common_name ?? val.name ?? null;
    return val;
}

const alleInfo = [
    { label: "Scientific name", waarde: plant.scientific_name },
    { label: "Family", waarde: plant.family_common_name ?? pakNaam(plant.family) },
    { label: "Genus", waarde: pakNaam(plant.genus) },
    { label: "Status", waarde: plant.status },
    { label: "Rank", waarde: plant.rank },
    { label: "Observations", waarde: soort.observations },
    { label: "Duration", waarde: soort.duration },
    { label: "Edible", waarde: soort.edible },
    { label: "Edible parts", waarde: soort.edible_part },
    { label: "Vegetable", waarde: soort.vegetable },
    { label: "Growth habit", waarde: specs.growth_habit },
    { label: "Growth rate", waarde: specs.growth_rate },
    { label: "Plant type", waarde: specs.ligneous_type },
    { label: "Avg. height (cm)", waarde: specs.average_height?.cm },
    { label: "Max. height (cm)", waarde: specs.maximum_height?.cm },
    { label: "Flower color", waarde: flower.color },
    { label: "Flower conspicuous", waarde: flower.conspicuous },
    { label: "Foliage color", waarde: foliage.color },
    { label: "Foliage texture", waarde: foliage.texture },
    { label: "Fruit color", waarde: fruit.color },
    { label: "Light (0-10)", waarde: growth.light },
    { label: "Humidity", waarde: growth.atmospheric_humidity },
    { label: "Min. temperature (°C)", waarde: growth.minimum_temperature?.deg_c },
    { label: "Max. temperature (°C)", waarde: growth.maximum_temperature?.deg_c },
];

const info = alleInfo
    .map((i) => ({ label: i.label, waarde: toonWaarde(i.waarde) }))
    .filter((i) => i.waarde !== null && i.waarde !== undefined && i.waarde !== "");


// Bouw een lijst conversationele "did you know?" feitjes uit de Trefle
// data. We slaan elk feitje over waar het bron-veld leeg is, zodat
// planten met weinig data geen rare halve zinnen tonen.
//
// Bron: alle velden komen uit het Trefle plant-object zoals beschreven
// in https://docs.trefle.io/reference/#tag/Plants
function bouwFeitjes() {
    const feitjes = [];

    // Familie
    const familie = plant.family_common_name ?? pakNaam(plant.family);
    if (familie) {
        feitjes.push(`This plant belongs to the ${familie} family.`);
    }

    // Eerste beschrijving (jaar + auteur)
    if (plant.year && plant.author) {
        feitjes.push(`First described by ${plant.author} in ${plant.year}.`);
    } else if (plant.year) {
        feitjes.push(`First described in ${plant.year}.`);
    }

    // Hoogte
    const maxHoogte = specs.maximum_height?.cm;
    if (maxHoogte) {
        const meters = (maxHoogte / 100).toFixed(maxHoogte >= 100 ? 1 : 2);
        feitjes.push(
            maxHoogte >= 100
                ? `Can grow up to ${meters} meters tall.`
                : `Stays small — usually under ${maxHoogte} cm.`
        );
    }

    // Bloemen
    if (Array.isArray(flower.color) && flower.color.length > 0) {
        const kleuren = flower.color.join(" and ");
        feitjes.push(`Has ${kleuren} flowers.`);
    } else if (flower.conspicuous === true) {
        feitjes.push("Known for its eye-catching flowers.");
    }

    // Blad
    if (Array.isArray(foliage.color) && foliage.color.length > 0) {
        feitjes.push(`The foliage is ${foliage.color.join(" and ")}.`);
    }

    // Eetbaarheid
    if (soort.edible === true) {
        const delen = Array.isArray(soort.edible_part)
            ? soort.edible_part.join(", ")
            : null;
        feitjes.push(
            delen
                ? `Edible — you can eat the ${delen}.`
                : "This plant is edible."
        );
    }

    // Groeneten
    if (soort.vegetable === true) {
        feitjes.push("Counts as a vegetable.");
    }

    // Groei-eigenschappen (alleen als de hoogte er nog niet bij verteld is)
    if (specs.growth_habit && !maxHoogte) {
        feitjes.push(`Growth habit: ${specs.growth_habit}.`);
    }

    // Vrucht / zaad
    if (Array.isArray(fruit.color) && fruit.color.length > 0) {
        feitjes.push(`Produces ${fruit.color.join(" and ")} fruit.`);
    }

    // Levensduur (annual / perennial / biennial)
    if (Array.isArray(soort.duration) && soort.duration.length > 0) {
        const lev = soort.duration.join(", ").toLowerCase();
        feitjes.push(`Lives as a ${lev} plant.`);
    }

    return feitjes;
}

const feitjes = bouwFeitjes();


function bepaalMoeilijkheid() {
    let punten = 0;
    let redenen = [];

    if (growth.light !== null && growth.light !== undefined) {
        if (growth.light >= 9 || growth.light <= 1) {
            punten += 2;
            redenen.push("has very specific light requirements");
        } else if (growth.light >= 7 || growth.light <= 3) {
            punten += 1;
        }
    }

    if (
        growth.atmospheric_humidity !== null &&
        growth.atmospheric_humidity !== undefined
    ) {
        if (growth.atmospheric_humidity >= 8 || growth.atmospheric_humidity <= 2) {
            punten += 2;
            redenen.push("requires specific humidity");
        } else if (
            growth.atmospheric_humidity >= 7 ||
            growth.atmospheric_humidity <= 3
        ) {
            punten += 1;
        }
    }

    const minT = growth.minimum_temperature?.deg_c;
    const maxT = growth.maximum_temperature?.deg_c;
    if (minT !== null && minT !== undefined && maxT !== null && maxT !== undefined) {
        const range = maxT - minT;
        if (range < 20) {
            punten += 2;
            redenen.push("narrow temperature range");
        } else if (range < 35) {
            punten += 1;
        }
    }

    const phMin = growth.ph_minimum;
    const phMax = growth.ph_maximum;
    if (phMin && phMax) {
        const phRange = phMax - phMin;
        if (phRange < 1.5) {
            punten += 1;
            redenen.push("specific soil pH");
        }
    }

    if (punten >= 4) {
        return {
            label: "Difficult",
            kleur: "#d9534f",
            uitleg:
                redenen.length > 0
                    ? `This plant ${redenen.join(", ")}.`
                    : "This plant has specific requirements.",
        };
    }
    if (punten >= 2) {
        return {
            label: "Medium",
            kleur: "#f0ad4e",
            uitleg: "Needs attention to get the right conditions.",
        };
    }
    if (punten === 0 && !growth.light && !growth.atmospheric_humidity) {
        return {
            label: "Unknown",
            kleur: "#999",
            uitleg: "Not enough data available.",
        };
    }
    return {
        label: "Easy",
        kleur: "#5cb85c",
        uitleg: "Tolerates a wide range of conditions.",
    };
}

const moeilijkheid = bepaalMoeilijkheid();
---

<main class="detail-wrapper">
    <a href="/#soorten" class="terug" onclick="if (history.length > 1) { event.preventDefault(); history.back(); }">&larr; Back</a>

    <article
        class="plant-card"
        data-plant-id={plant.id}
        data-plant-naam={plant.common_name ?? ""}
        data-plant-wet={plant.scientific_name ?? ""}
        data-plant-foto={plant.image_url ?? ""}
    >
        {plant.image_url ? (
            <img
                class="hoofd-foto"
                src={plant.image_url}
                alt={plant.common_name ?? plant.scientific_name}
            />
        ) : (
            <div class="geen-foto">No photo available</div>
        )}

        <div class="plant-info">
            <h1 class="naam">
                {plant.common_name ?? plant.scientific_name}
            </h1>
            {plant.scientific_name && plant.common_name && (
                <p class="wetenschappelijk">{plant.scientific_name}</p>
            )}

            <button class="tuin-knop" type="button">Save to garden</button>

            <!-- Watering panel - alleen zichtbaar als de plant in de tuin
                 zit. Het script hieronder togglet 'hidden' op basis van
                 bevatPlant(id). -->
            <section class="water-sectie" hidden>
                <p class="water-status">Not watered yet</p>

                <button class="water-knop" type="button">Mark as watered</button>

                <label class="water-interval">
                    Water every
                    <input
                        type="number"
                        class="water-interval-input"
                        min="1"
                        max="60"
                        step="1"
                    />
                    days
                </label>

                <button class="reminder-knop" type="button" hidden>
                    Enable reminders
                </button>
                <p class="reminder-status" hidden></p>
            </section>

            {feitjes.length > 0 && (
                <section class="feitjes">
                    <h2 class="feitjes-titel">Did you know?</h2>
                    <ul class="feitjes-lijst">
                        {feitjes.map((f) => (
                            <li>{f}</li>
                        ))}
                    </ul>
                </section>
            )}

            <div class="onderhoud">
                <span class="onderhoud-label">Care</span>
                <span
                    class="onderhoud-badge"
                    style={`background-color: ${moeilijkheid.kleur}`}
                >
                    {moeilijkheid.label}
                </span>
                <p class="onderhoud-uitleg">{moeilijkheid.uitleg}</p>
            </div>

            <ul class="info-grid">
                {info.map((item) => (
                    <li class="info-blokje">
                        <span class="info-label">{item.label}</span>
                        <span class="info-waarde">{item.waarde}</span>
                    </li>
                ))}
            </ul>

            {plant.bibliography && (
                <p class="bron"><strong>Source:</strong> {plant.bibliography}</p>
            )}
        </div>
    </article>
</main>

<script>
    // Save / remove knop + watering panel. Leest plant data uit
    // data-attributes op de .plant-card en praat met de localStorage
    // helpers in src/lib/tuin.js + notificatie helper in
    // src/lib/notificaties.js.
    //
    // Bronnen:
    // - dataset: https://developer.mozilla.org/en-US/docs/Web/API/HTMLElement/dataset
    // - Notification API: https://developer.mozilla.org/en-US/docs/Web/API/Notification
    import {
        opslaan,
        verwijderen,
        bevatPlant,
        laden,
        markeerWater,
        setWaterInterval,
        dagenSindsWater,
    } from "../lib/tuin.js";

    import {
        wordtOndersteund,
        huidigeStaat,
        vraagToestemming,
    } from "../lib/notificaties.js";

    const kaart = document.querySelector(".plant-card");
    const knop = document.querySelector(".tuin-knop");
    const waterSectie = document.querySelector(".water-sectie");
    const waterStatus = document.querySelector(".water-status");
    const waterKnop = document.querySelector(".water-knop");
    const intervalInput = document.querySelector(".water-interval-input");
    const reminderKnop = document.querySelector(".reminder-knop");
    const reminderStatus = document.querySelector(".reminder-status");

    if (kaart && knop) {
        const id = Number(kaart.dataset.plantId);

        // Pakt de plant uit de tuin (of null als niet opgeslagen).
        function huidigePlant() {
            return laden().find((p) => p.id === id) ?? null;
        }

        // Tekst voor "last watered" - in dagen, met nette pluralisatie.
        function statusTekst(plant) {
            const dagen = dagenSindsWater(plant);
            if (dagen === null) return "Not watered yet";
            if (dagen === 0) return "Watered today";
            if (dagen === 1) return "Watered 1 day ago";
            return `Watered ${dagen} days ago`;
        }

        // Vernieuwt save-knop label, water-sectie zichtbaarheid en alle
        // velden binnen die sectie.
        function ververs() {
            const plant = huidigePlant();
            const opgeslagen = !!plant;

            knop.textContent = opgeslagen ? "Remove from garden" : "Save to garden";
            knop.classList.toggle("opgeslagen", opgeslagen);

            waterSectie.hidden = !opgeslagen;
            if (!opgeslagen) return;

            waterStatus.textContent = statusTekst(plant);
            // Geef de "due" class als de plant water vraagt zodat de
            // status in oranje accentkleur wordt.
            const dagen = dagenSindsWater(plant);
            const overTijd =
                dagen === null ||
                (dagen !== null && dagen >= plant.interval_dagen);
            waterStatus.classList.toggle("dorstig", overTijd);

            // Alleen het input veld bijwerken als de gebruiker er nu niet
            // in typt (anders springt de cursor). Bron:
            // https://developer.mozilla.org/en-US/docs/Web/API/Document/activeElement
            if (document.activeElement !== intervalInput) {
                intervalInput.value = plant.interval_dagen;
            }

            // Reminder UI bijwerken op basis van Notification permission.
            ververReminderUi();
        }

        function ververReminderUi() {
            const staat = huidigeStaat();
            if (staat === "unsupported") {
                reminderKnop.hidden = true;
                reminderStatus.hidden = false;
                reminderStatus.textContent =
                    "Reminders aren't supported in this browser.";
                return;
            }
            if (staat === "granted") {
                reminderKnop.hidden = true;
                reminderStatus.hidden = false;
                reminderStatus.textContent = "Reminders are on.";
                return;
            }
            if (staat === "denied") {
                reminderKnop.hidden = true;
                reminderStatus.hidden = false;
                reminderStatus.textContent =
                    "Reminders are blocked. Allow notifications in your browser settings.";
                return;
            }
            // "default" - nog niet gevraagd
            reminderKnop.hidden = false;
            reminderStatus.hidden = true;
        }

        // Save / remove
        knop.addEventListener("click", () => {
            if (bevatPlant(id)) {
                verwijderen(id);
            } else {
                opslaan({
                    id,
                    common_name: kaart.dataset.plantNaam || null,
                    scientific_name: kaart.dataset.plantWet || null,
                    image_url: kaart.dataset.plantFoto || null,
                });
            }
            ververs();
        });

        // "Mark as watered"
        waterKnop.addEventListener("click", () => {
            markeerWater(id);
            ververs();
        });

        // Interval - bij elke change opslaan. We gebruiken 'change' (niet
        // 'input') zodat het niet bij elke pijltjes-tik schrijft.
        intervalInput.addEventListener("change", () => {
            setWaterInterval(id, intervalInput.value);
            ververs();
        });

        // Reminders aanzetten - moet uit een user gesture komen.
        reminderKnop.addEventListener("click", async () => {
            await vraagToestemming();
            ververReminderUi();
        });

        // Niet alleen bij paginalaad maar ook als een ander tabblad iets
        // wijzigt (bv. plant verwijderd in My Garden tab) - dan willen we
        // hier ook updaten zodat de UI niet stale is.
        if (wordtOndersteund) {
            window.addEventListener("storage", (event) => {
                if (event.key === "mijn-tuin") ververs();
            });
        }

        ververs();
    }
</script>

<style is:global>
    /* Tokens + body styling staan in public/styles/global.css */

    @layer reset, layout, components;

    @layer reset {
        .detail-wrapper ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }
    }

    @layer layout {
        .detail-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 1.5rem 1rem 140px;
        }

        .terug {
            align-self: flex-start;
            text-decoration: none;
            color: var(--clr-primary);
            font-weight: 500;
            margin-bottom: 1rem;
        }
    }

    @layer components {
        .plant-card {
            background: var(--clr-white);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: 0 8px 24px var(--clr-shadow);
            max-width: 600px;
            width: 100%;

            /* container query scope: info-grid reageert op kaart-breedte */
            container-type: inline-size;
            container-name: kaart;
        }

        .hoofd-foto,
        .geen-foto {
            width: 100%;
            height: 280px;
            object-fit: cover;
            display: block;
        }

        .geen-foto {
            background-color: var(--clr-bg-subtle);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--clr-muted);
        }

        .plant-info {
            padding: 1.5rem;
        }

        .naam {
            margin: 0 0 0.25rem;
            font-size: var(--fs-2);
            color: var(--clr-primary);
            text-align: center;
        }

        .wetenschappelijk {
            margin: 0 0 1.5rem;
            text-align: center;
            font-style: italic;
            color: var(--clr-muted);
        }

        /* Save / remove knop. Krijgt 'opgeslagen' class als de plant al
           in de tuin zit - dan wisselt 'ie naar accent-kleur. */
        .tuin-knop {
            display: block;
            width: 100%;
            margin: 0 0 1.5rem;
            padding: 0.9rem;
            border: none;
            border-radius: var(--radius-pill);
            background-color: var(--clr-primary);
            color: var(--clr-white);
            font-family: inherit;
            font-size: var(--fs-0);
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s ease;
        }

        .tuin-knop:hover {
            background-color: var(--clr-primary-dark);
        }

        .tuin-knop.opgeslagen {
            background-color: var(--clr-accent);
        }

        .tuin-knop.opgeslagen:hover {
            background-color: var(--clr-accent-dark);
        }

        /* Watering panel - alleen zichtbaar als de plant in de tuin
           zit. Eén class op de section + descendants voor alles binnen. */
        @scope (.water-sectie) {
            :scope {
                background: var(--clr-bg);
                border-radius: var(--radius-md);
                padding: 1rem;
                margin: 0 0 1.5rem;
                display: grid;
                gap: 0.75rem;
            }

            .water-status {
                margin: 0;
                text-align: center;
                font-size: var(--fs--1);
                color: var(--clr-muted);
            }

            /* Plant vraagt water → status in accent-kleur, vetjes */
            .water-status.dorstig {
                color: var(--clr-accent-dark);
                font-weight: 600;
            }

            .water-knop {
                padding: 0.7rem;
                border: none;
                border-radius: var(--radius-pill);
                background: var(--clr-primary);
                color: var(--clr-white);
                font-family: inherit;
                font-size: var(--fs-0);
                font-weight: 600;
                cursor: pointer;
                transition: background-color 0.2s ease;
            }
            .water-knop:hover {
                background: var(--clr-primary-dark);
            }

            .water-interval {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.5rem;
                font-size: var(--fs--1);
                color: var(--clr-text);
            }

            .water-interval-input {
                width: 4rem;
                padding: 0.4rem 0.6rem;
                border: 1px solid var(--clr-border);
                border-radius: var(--radius-sm);
                font-size: var(--fs--1);
                font-family: inherit;
                text-align: center;
            }

            .reminder-knop {
                padding: 0.6rem;
                border: 1px solid var(--clr-primary);
                border-radius: var(--radius-pill);
                background: transparent;
                color: var(--clr-primary);
                font-family: inherit;
                font-size: var(--fs--1);
                font-weight: 500;
                cursor: pointer;
            }
            .reminder-knop:hover {
                background: var(--clr-primary);
                color: var(--clr-white);
            }

            .reminder-status {
                margin: 0;
                text-align: center;
                font-size: var(--fs--2);
                color: var(--clr-muted);
            }
        }

        @scope (.feitjes) {
            :scope {
                background-color: var(--clr-bg);
                border-radius: var(--radius-md);
                padding: 1rem 1.25rem;
                margin-bottom: 1.5rem;
            }

            .feitjes-titel {
                margin: 0 0 0.6rem;
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: var(--clr-muted);
                font-weight: 600;
            }

            .feitjes-lijst {
                margin: 0;
                padding: 0;
                list-style: none;
                display: flex;
                flex-direction: column;
                gap: 0.45rem;
            }

            .feitjes-lijst li {
                position: relative;
                padding-left: 1.1rem;
                font-size: var(--fs--1);
                line-height: 1.5;
                color: var(--clr-text);
            }

            /* Kleine bullet als sierelement - geen UA bullet zodat 'ie
               op de juiste plek staat t.o.v. de hangende tekst.
               Bron: https://developer.mozilla.org/en-US/docs/Web/CSS/list-style */
            .feitjes-lijst li::before {
                content: "";
                position: absolute;
                left: 0;
                top: 0.55rem;
                width: 0.4rem;
                height: 0.4rem;
                border-radius: 50%;
                background: var(--clr-primary);
            }
        }

        @scope (.onderhoud) {
            :scope {
                background-color: var(--clr-bg);
                border-radius: var(--radius-md);
                padding: 1rem;
                text-align: center;
                margin-bottom: 1.5rem;
            }

            .onderhoud-label {
                display: block;
                font-size: 0.75rem;
                text-transform: uppercase;
                color: var(--clr-muted);
                letter-spacing: 1px;
                margin-bottom: 0.5rem;
            }

            .onderhoud-badge {
                display: inline-block;
                padding: 0.4rem 1.2rem;
                border-radius: var(--radius-pill);
                color: var(--clr-white);
                font-weight: 600;
                font-size: var(--fs-0);
            }

            .onderhoud-uitleg {
                margin: 0.6rem 0 0;
                font-size: var(--fs--1);
                color: #666;
                line-height: 1.4;
            }
        }

        .info-grid {
            margin: 0 0 1.5rem 0;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem;
        }

        @container kaart (width > 500px) {
            .info-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .info-blokje {
            background-color: var(--clr-bg);
            border-radius: var(--radius-sm);
            padding: 0.75rem 1rem;
            display: flex;
            flex-direction: column;
        }

        .info-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            color: var(--clr-muted);
            letter-spacing: 0.5px;
            margin-bottom: 0.2rem;
        }

