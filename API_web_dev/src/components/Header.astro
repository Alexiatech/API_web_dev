---
// Bottom-nav met drie knoppen: Species (overzicht), Scan (center, camera),
// en Garden (opgeslagen planten). De active class wordt door Layout.astro
// toegevoegd op basis van de URL hash.
//
// Iconen komen van Lucide (open-source icon set, MIT). Inline SVG zodat
// ze meekleuren met currentColor en geen losse network request nodig hebben.
// - List: https://lucide.dev/icons/list
// - Camera: https://lucide.dev/icons/camera
// - Sprout: https://lucide.dev/icons/sprout
---

<nav class="bottom-nav">
    <ul>
        <li>
            <a href="/#soorten">
                <!-- List: https://lucide.dev/icons/list -->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="8" y1="6" x2="21" y2="6"></line>
                    <line x1="8" y1="12" x2="21" y2="12"></line>
                    <line x1="8" y1="18" x2="21" y2="18"></line>
                    <line x1="3" y1="6" x2="3.01" y2="6"></line>
                    <line x1="3" y1="12" x2="3.01" y2="12"></line>
                    <line x1="3" y1="18" x2="3.01" y2="18"></line>
                </svg>
                <span>Species</span>
            </a>
        </li>

        <li>
            <a href="/#scan" aria-label="Scan a plant">
                <span class="center-btn">
                     <!-- Camera: https://lucide.dev/icons/camera -->
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path>
                        <circle cx="12" cy="13" r="3"></circle>
                    </svg>
                </span>
            </a>
        </li>

        <li>
            <a href="/#tuin">
                 <!-- Sprout: https://lucide.dev/icons/sprout -->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 20h10"></path>
                    <path d="M10 20c5.5-2.5.8-6.4 3-10"></path>
                    <path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"></path>
                    <path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"></path>
                </svg>
                <span>Garden</span>
            </a>
        </li>
    </ul>
</nav>

<style is:global>
   
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--clr-primary);
    border-radius: 24px 24px 0 0;
    padding: 10px 0;
    z-index: 1;
    ul {
        display: flex;
        justify-content: space-around;
        list-style: none;
        margin: 0;
        padding: 0;

        li:nth-child(2) {
        scale: 1.2;
        position: relative;
        top: -30px;
        }
    }

    a {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        text-decoration: none;
        color: white;
        font-size: 11px;
        font-weight: 500;
        padding: 4px 10px;
        border-radius: 999px;
        transition: color 0.2s ease, background 0.2s ease;
    }



    svg {
        width: 25px;
        height: 25px; 
    }
}
 

    .center-btn {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--clr-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);

        svg{
            scale: 1.2;
        }
    }



</style>
