---

---

<div class="zoek-container">
    <input
      type="text"
      id="zoek-input"
      placeholder="Zoek een plant..."
    />
    <button id="zoek-knop">Zoeken</button>
  
    <ul id="resultaten"></ul>
  </div>
  

  <script>
    const TOKEN = import.meta.env.PUBLIC_TREFLE_TOKEN;
    document.getElementById("zoek-knop").addEventListener("click", async () => {
      

      const query = document.getElementById("zoek-input").value;
      
     
      if (!query) return;
  
     
      const response = await fetch(`/api/planten?q=${query}`);
  
  
      const data = await response.json();
      const planten = data.data;
  
    
      const lijst = document.getElementById("resultaten");
      lijst.innerHTML = "";
  
      
      planten.forEach((plant) => {
        const item = document.createElement("li");
        item.textContent = plant.common_name ?? plant.scientific_name;
        lijst.appendChild(item);
      });
  
    });
  </script>

  <style>
    .zoek-container {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 1rem;
      background: linear-gradient(180deg, #87CEEB 0%, transparent 100%);
    }
  
    #zoek-input {
      width: 90%;
      padding: 0.8rem 1.2rem;
      border: none;
      border-radius: 2rem;
      font-size: 1rem;
      background-color: var(--second-color);
      color: var(--text-color-h);
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
      outline: none;
    }
  
    #zoek-input:focus {
      box-shadow: 0 2px 12px rgba(0,0,0,0.25);
    }
  
    #zoek-knop {
      margin-top: 0.5rem;
      padding: 0.6rem 2rem;
      border: none;
      border-radius: 2rem;
      background-color: #31594a;
      color: white;
      font-size: 1rem;
      cursor: pointer;
    }
  
    #zoek-knop:hover {
      background-color: #0A3323;
    }
  
    #resultaten {
      list-style: none;
      width: 90%;
      margin-top: 0.5rem;
      background-color: var(--second-color);
      border-radius: 1rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
      max-height: 200px;
      overflow-y: auto;
    }
  
    #resultaten li {
      padding: 0.7rem 1.2rem;
      color: var(--text-color-h);
      border-bottom: 1px solid rgba(0,0,0,0.05);
      cursor: pointer;
    }
  
    #resultaten li:hover {
      background-color: var(--accent-color);
      color: white;
    }

    .common_name{
        font-family: "Carter One", system-ui;
    }
  </style>