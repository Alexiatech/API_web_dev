---
const googleMapsKey = import.meta.env.PUBLIC_GOOGLE_TOKEN;
---

  <gmp-map
    center="38.7946,-106.5348"
    zoom="4"
    map-id="DEMO_MAP_ID"
  >
  </gmp-map>

  <script 
    async
    src="https://maps.googleapis.com/maps/api/js?key==${googleMapsKey}&libraries=maps,marker&v=beta">
  </script>

  <style>
    gmp-map{ 
        width: 100%;
        height: 400px;
        display: block;
        border-radius: 23px;
    }


  </style>